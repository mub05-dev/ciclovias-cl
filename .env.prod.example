# Copy this to .env.prod on the EC2 instance and fill in real values.
# Never commit .env.prod to git.

# Postgres credentials (choose strong values for production)
POSTGRES_USER=ciclovias
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=ciclovias_cl

# Mapbox public token (from mapbox.com dashboard)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...

# Public IP of the EC2 instance (update after provisioning)
EC2_PUBLIC_IP=0.0.0.0
